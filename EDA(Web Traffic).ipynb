  {
   "cell_type": "markdown",
   "id": "61d5e075-3efc-45bf-a6e0-3ebfd3475263",
   "metadata": {},
   "source": [
    "### Section 4 : Cleaning & Parsing"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "723d1c9c-6d7e-4a8f-a26d-a1d5206fe4c7",
   "metadata": {},
   "outputs": [],
   "source": [
    "df = df_raw.copy()\n",
    "\n",
    "# Normalize column names\n",
    "df.columns = df.columns.str.strip().str.replace('.', '_', regex=False).str.replace(' ', '_')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "c9dfff58-9468-4eb4-85ac-94d7a2186ef2",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Strip commas from numeric columns\n",
    "for col in NUM_COLS:\n",
    "    if df[col].dtype == object:\n",
    "        df[col] = df[col].str.replace(',', '', regex=False).astype(float)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "171b5d36-065d-47c5-9165-2eb9df0105aa",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Parse dates\n",
    "df['Date'] = pd.to_datetime(df['Date'], infer_datetime_format=True)\n",
    "df = df.sort_values('Date').reset_index(drop=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "ff1a5124-dc6d-4933-bc8a-3af6c96621b7",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Fill nulls\n",
    "df[NUM_COLS] = df[NUM_COLS].fillna(method='ffill').fillna(method='bfill')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "1b1fd948-4b27-47de-8176-d6e202de0e84",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Drop duplicate dates\n",
    "df = df.drop_duplicates(subset='Date').reset_index(drop=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "87877a95-7c96-42af-8938-6d73b99c53bd",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Outliers clipped: 0\n"
     ]
    }
   ],
   "source": [
    "# Soft clip outliers (IQR x3) on Page_Loads\n",
    "Q1, Q3 = df['Page_Loads'].quantile([0.25, 0.75])\n",
    "IQR = Q3 - Q1\n",
    "n_out = ((df['Page_Loads'] < Q1-3*IQR) | (df['Page_Loads'] > Q3+3*IQR)).sum()\n",
    "df['Page_Loads'] = df['Page_Loads'].clip(lower=Q1-3*IQR, upper=Q3+3*IQR)\n",
    "print(f'Outliers clipped: {n_out}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "b031ae7b-5f7b-4372-8891-e710f6e35dfd",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Add helper columns\n",
    "df['DayName'] = df['Date'].dt.day_name()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "e9067830-f7db-49ab-82b5-1093b56b31e2",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
