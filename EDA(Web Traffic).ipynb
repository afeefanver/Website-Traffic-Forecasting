   ]
  },
  {
   "cell_type": "code",
   "execution_count": 29,
   "id": "98fdf0fa-4f6f-4c72-94fd-87d7f7927548",
   "metadata": {},
   "outputs": [],
   "source": [
    "series = df.set_index('Date')['Page_Loads']"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 30,
   "id": "4f396dfa-eb4c-4588-9380-0d7bd1d060f0",
   "metadata": {},
   "outputs": [],
   "source": [
    "def run_adf(s, label=''):\n",
    "    r = adfuller(s.dropna())\n",
    "    print(f'\\n-- ADF [{label}]  stat={r[0]:.4f}  p={r[1]:.4f}')\n",
    "    for k, v in r[4].items(): print(f'   CV {k}: {v:.4f}')\n",
    "    print('   => STATIONARY' if r[1] < 0.05 else '   => NON-STATIONARY')\n",
    "    return r[1] < 0.05"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 31,
   "id": "08d0aa2f-3df5-44d1-94e7-c22eca777b93",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "-- ADF [Original]  stat=-4.2838  p=0.0005\n",
      "   CV 1%: -3.4334\n",
      "   CV 5%: -2.8629\n",
      "   CV 10%: -2.5675\n",
      "   => STATIONARY\n"
     ]
    }
   ],
   "source": [
    "stat = run_adf(series, 'Original')\n",
    "if not stat:\n",
    "    run_adf(series.diff().dropna(), '1st-Diff')"
   ]
  },
